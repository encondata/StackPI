# StackPI_v2 — Test Deploy Configuration (template)
# Copy this file to scripts/.env.test_deploy and fill in real values.
# scripts/.env.test_deploy is gitignored — never commit real credentials.

# Pi SSH connection
PI_HOST=192.168.1.100
PI_USER=pi
PI_PASSWORD=changeme
PI_SSH_PORT=22

# Where on the Pi to rsync this repo to
PI_DEPLOY_PATH=/home/pi/StackPI_v2
